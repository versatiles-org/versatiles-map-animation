{
	"name": "versatiles-map-animation",
	"version": "0.1.0",
	"description": "Prototype tool for composing map camera animations on a timeline (VersaTiles).",
	"private": true,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/versatiles-org/versatiles-map-animation.git"
	},
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check": "npm run format && npm run check:svelte && npm run lint && npm run test",
		"format": "prettier --log-level=warn --write .",
		"format:check": "prettier --log-level=warn --check .",
		"lint": "eslint .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.1",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.5",
		"@versatiles/style": "^5.10.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"happy-dom": "^20.9.0",
		"maplibre-gl": "^5.24.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vitest": "^4.1.5"
	}
}
